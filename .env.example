# ─── Multi-Sport Prediction Bot — Environment Variables ───────────────────────
# Multiple keys per API: separate with commas, no spaces.
# The bot tries keys in order — if one hits 403/429/error, it auto-rotates to the next.

# ─── FOOTBALL (api-football.com) ──────────────────────────────────────────────
# Add up to 5 free keys for maximum daily coverage (100 req/day each)
# Get keys at: https://www.api-football.com
FOOTBALL_API_KEYS=key1,key2,key3

# ─── NBA (balldontlie.io) ─────────────────────────────────────────────────────
# Free tier — no daily limit. Add multiple accounts for redundancy.
# Get keys at: https://app.balldontlie.io
BALLDONTLIE_KEYS=key1,key2

# ─── TENNIS (api-sports tennis) ───────────────────────────────────────────────
# Free key from api-tennis.com
# Get keys at: https://api-tennis.com
TENNIS_API_KEYS=key1,key2

# TENNIS (RapidAPI ATP/WTA/ITF) — supports multiple keys (comma-separated)
RAPIDAPI_TENNIS_KEYS=key1,key2
RAPIDAPI_TENNIS_HOST=tennis-api-atp-wta-itf.p.rapidapi.com
TENNIS_PROVIDER=rapidapi

# ─── TELEGRAM ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather | Chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
